
# --- PASS 1: The Build Environment ---
FROM node:20-alpine AS builder
WORKDIR /app

# Install dependencies first to leverage caching
COPY package*.json ./
RUN npm ci

# Copy source and compile the project
COPY . .
RUN npm run build

# --- PASS 2: The Production Environment ---
FROM nginx:alpine AS runner
WORKDIR /usr/share/nginx/html

# Clean the default Nginx public files
RUN rm -rf ./*

# Copy ONLY the compiled static assets from Pass 1
COPY --from=builder /app/dist .

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]

